    e "Berasa letih tidak bermakna anda telah gagal."

# game/script.rpy:1914
translate malay affective_input_7efac721_1:

    # e "It may simply be a sign that you have been carrying a lot."
    e "Ia mungkin sekadar tanda bahawa anda telah memikul terlalu banyak perkara."

# game/script.rpy:1917
translate malay affective_input_23ad3936_1:

    # e "Even if it's difficult to put into words, what you're feeling is still important."
    e "Walaupun sukar untuk diluahkan dengan kata-kata, apa yang anda rasakan tetap penting."

# game/script.rpy:1919
translate malay affective_input_9452db89_1:

    # e "You do not need to have all the answers right now."
    e "Anda tidak perlu mempunyai semua jawapan sekarang."

# game/script.rpy:1920
translate malay affective_input_ed168f9b_1:

    # e "We can simply take things one step at a time."
    e "Kita boleh mengambilnya satu langkah pada satu masa."

# game/script.rpy:1927
translate malay affective_input_de275859:

    # e "Thank you for helping me understand your experience."
    e "Terima kasih kerana membantu saya memahami pengalaman anda."

# game/script.rpy:1928
translate malay affective_input_a39dfa92:

    # e "I'd like to reflect on what you've shared before we continue."
    e "Saya ingin merenungkan apa yang anda kongsikan sebelum kita meneruskan."

# game/script.rpy:1939
translate malay affective_input_a755bf15:

    # e "There's no need to rush."
    e "Tidak perlu tergesa-gesa."

# game/script.rpy:1940
translate malay affective_input_33f3cb69:

    # e "let's take things at a pace that feels comfortable for you."
    e "Mari kita bergerak mengikut rentak yang selesa untuk anda."

# game/script.rpy:1951
translate malay affective_input_09710aa7:

    # e "It sounds like there may be more beneath the surface of what you've shared."
    e "Nampaknya mungkin ada perkara lain yang tersimpan di sebalik apa yang anda kongsikan."

# game/script.rpy:1953
translate malay affective_input_f2498ea9:

    # e "I'm right here with you, [user_name]."
    e "Saya ada di sini bersama anda, [user_name]."

# game/script.rpy:1992
translate malay calming_loop_0a5f8814:

    # e "Let's try one more. This one is a little different."
    e "Mari kita cuba satu lagi. Yang ini sedikit berbeza."

# game/script.rpy:1999
translate malay calming_loop_1c1584d4:

    # e "How are you feeling now, [user_name]?"
    e "Bagaimana perasaan anda sekarang, [user_name]?"

# game/script.rpy:2061
translate malay calming_loop_3f22bcbf:

    # e "[exit_msg]"
    e "[exit_msg]"

# game/script.rpy:2071
translate malay calming_loop_b3111fb3:

    # e "[calm_close]"
    e "[calm_close]"

# game/script.rpy:2073
translate malay calming_loop_ac54d61c:

    # e "Hold onto that, [user_name]. Be gentle with yourself today."
    e "Peganglah perasaan itu, [user_name]. Bersikap lembut terhadap diri anda hari ini."

# game/script.rpy:2082
translate malay calming_loop_5736322c:

    # e "[keep_going]"
    e "[keep_going]"

# game/script.rpy:2086
translate malay calming_loop_ad017a4c:

    # e "We tried a few things together, and I appreciate you staying with me."
    e "Kita telah mencuba beberapa perkara bersama, dan saya menghargai kesudian anda untuk terus bersama saya."

# game/script.rpy:2087
translate malay calming_loop_24f779b6:

    # e "If things continue to feel heavy, please reach out through Befrienders or talk to someone you trust."
    e "Jika keadaan masih terasa berat, sila hubungi Befrienders atau bercakap dengan seseorang yang anda percayai."

# game/script.rpy:2088
translate malay calming_loop_2eb8ff65:

    # e "You do not have to handle this alone."
    e "Anda tidak perlu menghadapinya seorang diri."

# game/script.rpy:2090
translate malay calming_loop_9f819c24:

    # e "Thank you for showing up for yourself today, [user_name]."
    e "Terima kasih kerana meluangkan masa untuk menjaga diri anda hari ini, [user_name]."

# game/script.rpy:2109
translate malay deliver_technique_d3475daf:

    # e "Let's start with a simple breathing exercise."
    e "Mari kita mulakan dengan latihan pernafasan yang ringkas."

# game/script.rpy:2110
translate malay deliver_technique_058bf89a:

    # e "When we're stressed, our breathing often becomes quicker and shallower without us noticing."
    e "Apabila kita tertekan, pernafasan kita sering menjadi lebih cepat dan cetek tanpa kita sedari."

# game/script.rpy:2111
translate malay deliver_technique_c943a211:

    # e "Slowing the breath can help the body feel calmer and more settled."
    e "Memperlahankan pernafasan boleh membantu tubuh berasa lebih tenang dan stabil."

# game/script.rpy:2113
translate malay deliver_technique_ad731e97:

    # e "Let's do it together at a comfortable pace."
    e "Mari kita lakukannya bersama-sama mengikut rentak yang selesa."

# game/script.rpy:2115
translate malay deliver_technique_05cba651:

    # e "Breathe in gently through your nose for four counts."
    e "Tarik nafas perlahan-lahan melalui hidung selama empat saat."

# game/script.rpy:2116
translate malay deliver_technique_d3655eb1:

    # e "In.. one, two, three, four."
    e "Tarik nafas... satu, dua, tiga, empat."

# game/script.rpy:2117
translate malay deliver_technique_b4335ba3:

    # e "Hold for a moment."
    e "Tahan seketika."

# game/script.rpy:2118
translate malay deliver_technique_89e41e7b:

    # e "Hold.. two, three,four, five, six, seven."
    e "Tahan... dua, tiga, empat, lima, enam, tujuh."

# game/script.rpy:2119
translate malay deliver_technique_f0519a3a:

    # e "Now breathe out slowly through your mouth for eight counts."
    e "Sekarang hembus nafas perlahan-lahan melalui mulut selama lapan saat."

# game/script.rpy:2120
translate malay deliver_technique_f3f5f042:

    # e "two, three, four, five, six, seven, eight."
    e "Dua, tiga, empat, lima, enam, tujuh, lapan."

# game/script.rpy:2122
translate malay deliver_technique_63579d40:

    # e "There you go."
    e "Bagus."

# game/script.rpy:2123
translate malay deliver_technique_a7d30054:

    # e "Okay, one more round."
    e "Baiklah, sekali lagi."

# game/script.rpy:2124
translate malay deliver_technique_d3655eb1_1:

    # e "In.. one, two, three, four."
    e "Tarik nafas... satu, dua, tiga, empat."

# game/script.rpy:2125
translate malay deliver_technique_9b6c8794:

    # e "Hold.. two, three, four, five, six, seven."
    e "Tahan... dua, tiga, empat, lima, enam, tujuh."

# game/script.rpy:2126
translate malay deliver_technique_966ef7e6:

    # e "And out.. two, three, four, five, six, seven, eight."
    e "Dan hembus... dua, tiga, empat, lima, enam, tujuh, lapan."

# game/script.rpy:2128
translate malay deliver_technique_5e5ee7ef:

    # e "Well done."
    e "Bagus."

# game/script.rpy:2129
translate malay deliver_technique_1cc12b49:

    # e "Even a few slow breaths can help create a sense of calm."
    e "Walaupun hanya beberapa nafas yang perlahan, ia boleh membantu mewujudkan rasa tenang."

# game/script.rpy:2133
translate malay deliver_technique_3f1da05e:

    # e "This exercise is called the 5-4-3-2-1 grounding technique."
    e "Latihan ini dikenali sebagai teknik grounding 5-4-3-2-1."

# game/script.rpy:2134
translate malay deliver_technique_8a9b2db2:

    # e "When we're feeling stressed or overwhelmed, it's easy for our thoughts to race ahead."
    e "Apabila kita berasa tertekan atau terlalu terbeban, fikiran kita mudah melayang jauh."

# game/script.rpy:2135
translate malay deliver_technique_dadb475a:

    # e "Grounding helps us reconnect with the present moment by paying attention to what we can see, hear, feel, smell, and taste."
    e "Grounding membantu kita kembali kepada saat ini dengan memberi perhatian kepada apa yang boleh kita lihat, dengar, sentuh, hidu dan rasa."

# game/script.rpy:2137
translate malay deliver_technique_01ed048e:

    # e "Take a look around wherever you are. There's no rush."
    e "Lihat sekeliling anda. Tidak perlu tergesa-gesa."

# game/script.rpy:2139
translate malay deliver_technique_95587b8d:

    # e "First, notice 5 things you can see."
    e "Pertama, perhatikan 5 perkara yang anda boleh lihat."

# game/script.rpy:2140
translate malay deliver_technique_9145870f:

    # e "Now 4 things you can physically touch or feel, such as your chair, your clothes, or your hands."
    e "Sekarang 4 perkara yang anda boleh sentuh atau rasakan secara fizikal, seperti kerusi, pakaian atau tangan anda."

# game/script.rpy:2141
translate malay deliver_technique_280bf28a:

    # e "Next, listen for 3 sounds around you. Even very quiet sounds count."
    e "Seterusnya, dengarkan 3 bunyi di sekeliling anda. Bunyi yang sangat perlahan juga dikira."

# game/script.rpy:2142
translate malay deliver_technique_1197246a:

    # e "Then notice 2 things you can smell, or remember smelling recently."
    e "Kemudian, perhatikan 2 perkara yang anda boleh hidu, atau bau yang anda ingat baru-baru ini."

# game/script.rpy:2143
translate malay deliver_technique_5eb12ef7:

    # e "And finally, 1 thing you can taste right now."
    e "Dan akhir sekali, 1 perkara yang anda boleh rasa sekarang."

# game/script.rpy:2145
translate malay deliver_technique_84324f4b:

    # e "Thank you for taking a moment to do that."
    e "Terima kasih kerana meluangkan sedikit masa untuk melakukan latihan ini."

# game/script.rpy:2146
translate malay deliver_technique_c2291b22:

    # e "Right now, you're here, in this moment, and that's enough."
    e "Pada saat ini, anda berada di sini, dalam detik ini, dan itu sudah memadai."

# game/script.rpy:2150
translate malay deliver_technique_5d0a7271:

    # e "Let's try a brief body scan exercise."
    e "Mari kita cuba latihan body scan yang ringkas."

# game/script.rpy:2151
translate malay deliver_technique_e19a6d2f:

    # e "Stress can sometimes show up in the body without us realising it."
    e "Kadangkala tekanan muncul dalam tubuh tanpa kita sedari."

# game/script.rpy:2152
translate malay deliver_technique_f71b9ebc:

    # e "You might notice tension in your shoulders, jaw, neck, or hands."
    e "Anda mungkin menyedari ketegangan pada bahu, rahang, leher atau tangan."

# game/script.rpy:2154
translate malay deliver_technique_7cdccbb0:

    # e "Take a moment to check in with your body."
    e "Luangkan sedikit masa untuk memeriksa keadaan tubuh anda."

# game/script.rpy:2156
translate malay deliver_technique_34b81c85:

    # e "Start with your shoulders and gently let them relax away from your ears."
    e "Mulakan dengan bahu anda dan perlahan-lahan biarkan ia relaks menjauhi telinga."

# game/script.rpy:2157
translate malay deliver_technique_e2187207:

    # e "Now notice your jaw. Allow it to soften, and let your tongue rest comfortably."
    e "Sekarang perhatikan rahang anda. Biarkan ia menjadi lebih santai dan lidah anda berehat dengan selesa."

# game/script.rpy:2158
translate malay deliver_technique_9384d221:

    # e "Next, notice your hands. Let them relax and rest naturally."
    e "Seterusnya, perhatikan tangan anda. Biarkan ia relaks dan berehat secara semula jadi."

# game/script.rpy:2159
translate malay deliver_technique_e768c9a4:

    # e "Now bring your attention to the rest of your body."
    e "Sekarang alihkan perhatian anda kepada seluruh tubuh."

# game/script.rpy:2160
translate malay deliver_technique_a47d50e0:

    # e "Notice your neck, chest, stomach, or anywhere else that feels tense."
    e "Perhatikan leher, dada, perut atau mana-mana bahagian lain yang terasa tegang."

# game/script.rpy:2162
translate malay deliver_technique_8f7800cd:

    # e "If you notice an area of tension, simply acknowledge it."
    e "Jika anda menyedari kawasan yang tegang, hanya akui kewujudannya."

# game/script.rpy:2163
translate malay deliver_technique_e3c8f64e:

    # e "There is no need to change anything right now."
    e "Tidak perlu mengubah apa-apa buat masa ini."

# game/script.rpy:2164
translate malay deliver_technique_247ad6b8:

    # e "Just take a slow breath and allow yourself to notice how it feels."
    e "Cuma tarik nafas perlahan dan benarkan diri anda merasai bagaimana keadaannya."

# game/script.rpy:2166
translate malay deliver_technique_84324f4b_1:

    # e "Thank you for taking a moment to do that."
    e "Terima kasih kerana meluangkan sedikit masa untuk melakukan latihan ini."

# game/script.rpy:2167
translate malay deliver_technique_d50156ff:

    # e "Sometimes simply noticing tension is the first step towards letting it go."
    e "Kadangkala hanya dengan menyedari ketegangan itu sudah menjadi langkah pertama untuk melepaskannya."

# game/script.rpy:2171
translate malay deliver_technique_4faf03cd:

    # e "Let's try a brief gratitude exercise."
    e "Mari kita cuba latihan kesyukuran yang ringkas."

# game/script.rpy:2173
translate malay deliver_technique_3e25f0be:

    # e "When we're under stress, our attention is often drawn towards problems, worries, and unfinished tasks."
    e "Apabila kita berada dalam tekanan, perhatian kita selalunya tertumpu kepada masalah, kebimbangan dan tugasan yang belum selesai."

# game/script.rpy:2174
translate malay deliver_technique_85d9ed2b:

    # e "Taking a moment to notice something positive can help create a little balance."
    e "Meluangkan sedikit masa untuk menyedari sesuatu yang positif boleh membantu mewujudkan sedikit keseimbangan."

# game/script.rpy:2176
translate malay deliver_technique_c9a62bae:

    # e "I'd like you to think of one thing that has felt good, comforting, or meaningful recently."
    e "Saya ingin anda memikirkan satu perkara yang membuatkan anda berasa gembira, selesa atau bermakna baru-baru ini."

# game/script.rpy:2177
translate malay deliver_technique_a9fd9997:

    # e "It doesn't need to be something big."
    e "Ia tidak semestinya sesuatu yang besar."

# game/script.rpy:2178
translate malay deliver_technique_71b23bb9:

    # e "It could be a pleasant conversation, a favourite meal, a moment of quiet, or something that made you smile."
    e "Ia boleh jadi perbualan yang menyenangkan, makanan kegemaran, saat yang tenang, atau sesuatu yang membuatkan anda tersenyum."

# game/script.rpy:2180
translate malay deliver_technique_5fedc8fa:

    # e "Take a moment to bring that experience to mind."
    e "Luangkan sedikit masa untuk mengingati pengalaman tersebut."

# game/script.rpy:2181
translate malay deliver_technique_4a065ee0:

    # e "Notice how it felt, and allow yourself to sit with it for a few seconds."
    e "Perhatikan bagaimana perasaan itu, dan benarkan diri anda menikmatinya selama beberapa saat."

# game/script.rpy:2182
translate malay deliver_technique_faf4e5c0:

    # e "Sometimes small positive moments deserve a little more attention than we usually give them."
    e "Kadangkala saat-saat positif yang kecil wajar diberi lebih perhatian daripada yang biasa kita berikan."

# game/script.rpy:2187
translate malay deliver_technique_a4e33544:

    # e "Let's try a guided imagery exercise."
    e "Mari kita cuba latihan imaginasi berpandu."

# game/script.rpy:2188
translate malay deliver_technique_357fd37f:

    # e "Guided imagery involves imagining a calm and peaceful place in as much detail as possible."
    e "Latihan imaginasi berpandu melibatkan membayangkan tempat yang tenang dan damai dengan seberapa banyak perincian yang mungkin."

# game/script.rpy:2189
translate malay deliver_technique_3215352f:

    # e "Many people find it helpful for slowing down and creating a sense of calm during stressful moments."
    e "Ramai orang mendapati ia membantu untuk memperlahankan fikiran dan mewujudkan rasa tenang ketika menghadapi tekanan."

# game/script.rpy:2191
translate malay deliver_technique_7502d0fc:

    # e "Take a moment to imagine a place where you feel safe, comfortable, and at ease."
    e "Luangkan sedikit masa untuk membayangkan satu tempat yang membuatkan anda berasa selamat, selesa dan tenang."

# game/script.rpy:2192
translate malay deliver_technique_a2705082:

    # e "It could be a beach, a quiet lake, a forest, or any place that feels peaceful to you."
    e "Ia boleh jadi pantai, tasik yang sunyi, hutan, atau mana-mana tempat yang memberi ketenangan kepada anda."

# game/script.rpy:2194
translate malay deliver_technique_7885b2b3:

    # e "If you'd like, gently close your eyes and picture the scene."
    e "Jika anda mahu, pejamkan mata perlahan-lahan dan bayangkan suasana tersebut."

# game/script.rpy:2195
translate malay deliver_technique_7529fdd9:

    # e "Notice what you can see around you. The colours, the light, and the details of the environment."
    e "Perhatikan apa yang anda lihat di sekeliling. Warna-warna, cahaya dan perincian persekitarannya."

# game/script.rpy:2196
translate malay deliver_technique_0a9c9b7f:

    # e "Now bring your attention to the sounds."
    e "Sekarang alihkan perhatian anda kepada bunyi-bunyi di sekeliling."

# game/script.rpy:2197
translate malay deliver_technique_145d7613:

    # e "Perhaps you can hear gentle waves, birds in the distance, or the sound of a light breeze."
    e "Mungkin anda dapat mendengar ombak yang perlahan, kicauan burung dari jauh, atau hembusan angin yang lembut."

# game/script.rpy:2198
translate malay deliver_technique_85db38f7:

    # e "Notice any physical sensations."
    e "Perhatikan juga sebarang sensasi fizikal."

# game/script.rpy:2199
translate malay deliver_technique_3a90d591:

    # e "You might imagine warm sunlight on your skin, cool air around you, or soft ground beneath your feet."
    e "Anda mungkin membayangkan cahaya matahari yang hangat pada kulit, udara yang nyaman, atau permukaan lembut di bawah kaki."

# game/script.rpy:2201
translate malay deliver_technique_8f14b38d:

    # e "Take a slow breath in."
    e "Tarik nafas perlahan-lahan."

# game/script.rpy:2202
translate malay deliver_technique_b13a7fdb:

    # e "And slowly breathe out."
    e "Dan hembuskan nafas dengan perlahan."

# game/script.rpy:2203
translate malay deliver_technique_9c20a90e:

    # e "Allow yourself to stay in this peaceful place for a few moments."
    e "Benarkan diri anda berada di tempat yang damai ini untuk beberapa ketika."

# game/script.rpy:2204
translate malay deliver_technique_47565ece:

    # e "Whenever things begin to feel overwhelming, you can return to this image and give yourself a moment to pause."
    e "Apabila keadaan mula terasa terlalu membebankan, anda boleh kembali kepada gambaran ini dan memberi ruang kepada diri anda untuk berehat seketika."

# game/script.rpy:2266
translate malay phase5_close_update_d81c97f8:

    # e "Thank you for spending this time with me, [user_name]."
    e "Terima kasih kerana meluangkan masa bersama saya, [user_name]."

# game/script.rpy:2274
translate malay phase5_close_update_05ee27ee:

    # e "[close_line]"
    e "[close_line]"

# game/script.rpy:2276
translate malay phase5_close_update_f84678a8:

    # e "Take care of yourself today."
    e "Jagalah diri anda hari ini."

# game/script.rpy:2284
translate malay phase5_close_update_05ee27ee_1:

    # e "[close_line]"
    e "[close_line]"

# game/script.rpy:2286
translate malay phase5_close_update_011c6d10:

    # e "If things continue to feel heavy, please reach out through BeHealth or talk to someone you trust."
    e "Jika keadaan terus terasa berat, sila hubungi BeHealth atau bercakap dengan seseorang yang anda percayai."

# game/script.rpy:2287
translate malay phase5_close_update_2e4c5efd:

    # e "You do not have to carry this alone."
    e "Anda tidak perlu membawa ini bersendirian."

# game/script.rpy:2289
translate malay phase5_close_update_39e0c1af:

    # e "I'll be here when you come back."
    e "Saya akan berada di sini apabila anda kembali."

# game/script.rpy:2297
translate malay phase5_close_update_05ee27ee_2:

    # e "[close_line]"
    e "[close_line]"

# game/script.rpy:2299
translate malay phase5_close_update_ddc8ca5f:

    # e "See you next time, [user_name]."
    e "Jumpa lagi di lain waktu, [user_name]."


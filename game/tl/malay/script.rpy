# game/script.rpy:1811
translate malay affective_input_562112ce:

    # e "When things start to feel difficult, which part tends to weigh on you the most?"
    e "Apabila keadaan mula terasa sukar, bahagian manakah yang paling membebankan anda?"

# game/script.rpy:1828
translate malay affective_input_84563566:

    # e "Trying to balance caregiving with everything else can be incredibly demanding."
    e "Mencuba mengimbangi tanggungjawab menjaga seseorang dengan perkara lain boleh menjadi sangat mencabar."

# game/script.rpy:1830
translate malay affective_input_e471d113:

    # e "It is not easy to meet so many responsibilites at once."
    e "Bukan mudah untuk memikul begitu banyak tanggungjawab pada masa yang sama."

# game/script.rpy:1831
translate malay affective_input_3733a235:

    # e "For now,let's focus on one small step at a time."
    e "Buat masa ini, mari kita fokus kepada satu langkah kecil dahulu."

# game/script.rpy:1835
translate malay affective_input_694889dc:

    # e "Caring deeply about someone often comes with a lot of worry."
    e "Apabila kita benar-benar mengambil berat tentang seseorang, kebimbangan selalunya datang bersama-sama."

# game/script.rpy:1838
translate malay affective_input_c107b358:

    # e "That concern shows how important they are to you."
    e "Kebimbangan itu menunjukkan betapa pentingnya mereka kepada anda."

# game/script.rpy:1839
translate malay affective_input_e8716c43:

    # e "Let's take a moement to slow down and breathe together."
    e "Mari kita luangkan sedikit masa untuk bertenang dan bernafas bersama."

# game/script.rpy:1843
translate malay affective_input_131621e1:

    # e "It sounds like you've been giving a great deal of yourself for a long time."
    e "Nampaknya anda telah banyak berkorban dan memberi selama tempoh yang lama."

# game/script.rpy:1845
translate malay affective_input_f97ad499:

    # e "Feeling exhausted does not mean you have failed."
    e "Berasa letih tidak bermakna anda telah gagal."

# game/script.rpy:1846
translate malay affective_input_7efac721:

    # e "It may simply be a sign that you have been carrying a lot."
    e "Ia mungkin sekadar tanda bahawa anda telah memikul terlalu banyak perkara."

# game/script.rpy:1849
translate malay affective_input_23ad3936:

    # e "Even if it's difficult to put into words, what you're feeling is still important."

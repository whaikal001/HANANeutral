    e "Pengguna dikenal pasti sebagai [user_name]."

# game/script.rpy:740
translate malay start_643fd6a3:

    # e "My name means \"flower\" in Japanese and \"happiness\" in Arabic."
    e "Nama saya bermaksud \"bunga\" dalam bahasa Jepun dan \"kebahagiaan\" dalam bahasa Arab."


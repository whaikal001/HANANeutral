    # e "Input received. Beginning session."
    e "Input diterima. Memulakan sesi."

# game/script.rpy:760
translate malay start_ca687f24:

    # e "Before we continue, would you like background music during this session?"
    e "Sebelum kita teruskan, adakah anda mahu muzik latar sepanjang sesi ini?"

# game/script.rpy:761
translate malay start_b03ae540:

    # e "You can choose either."
    e "Anda boleh memilih mana-mana."

# game/script.rpy:767
translate malay start_d2c7d8fc:

    # e "Music will play in the background."
    e "Muzik akan dimainkan di latar belakang."

# game/script.rpy:773
translate malay start_8b1446cc:

    # e "No music will play."
    e "Tiada muzik akan dimainkan."

# game/script.rpy:787
translate malay start_2780dd0c:

    # e "Please select your current state today"
    e "Sila pilih keadaan anda hari ini"

# game/script.rpy:806
translate malay start_5d1beeff:

    # e "How has your day been so far?"
    e "Bagaimana hari anda setakat ini?"

# game/script.rpy:825
translate malay start_406e37dc:

    # e "Did anything feel stressful or frustrating for you today?"
    e "Adakah sesuatu terasa menekan atau mengecewakan bagi anda hari ini?"

# game/script.rpy:844
translate malay start_1d3e3cf9:

    # e "One more question."
    e "Satu soalan lagi."

# game/script.rpy:845
translate malay start_21bc042b:

    # e "Identify any recent positive event, if applicable."
    e "Kenal pasti sebarang peristiwa positif kebelakangan ini, jika ada."

# game/script.rpy:902
translate malay stress_input_6e654e04:

    # e "[q!t]"
    e "[q!t]"

# game/script.rpy:933
translate malay stress_input_618d2c18:

    # e "Responses recorded."
    e "Jawapan direkodkan."

# game/script.rpy:978
translate malay stress_input_d88c88d3:

    # e "If you ever feel unsafe, contact Befrienders or a healthcare professional. External support options are available."
    e "Jika anda berasa tidak selamat, sila hubungi Befrienders atau seorang profesional penjagaan kesihatan. Pilihan sokongan luar tersedia."

# game/script.rpy:979
translate malay stress_input_f1049801:

    # e "Let's start with a short calming exercise."
    e "Mari kita mulakan dengan latihan menenangkan diri yang ringkas."

# game/script.rpy:987
translate malay stress_input_93d9917d:

    # e "The next section identifies stress factors and possible actions."
    e "Bahagian seterusnya mengenal pasti faktor tekanan dan tindakan yang mungkin diambil."

# game/script.rpy:1007
translate malay session_end_loop_8b82f119:

    # e "That exercise is complete."
    e "Latihan itu telah selesai."

# game/script.rpy:1008
translate malay session_end_loop_4abefe74:

    # e "You can do another coping exercise, or end the session here."
    e "Anda boleh melakukan satu lagi latihan menangani tekanan, atau menamatkan sesi di sini."

# game/script.rpy:1038
translate malay session_end_loop_89917604:

    # e "A short breathing exercise is available before ending."
    e "Satu latihan pernafasan ringkas tersedia sebelum menamatkan sesi."

# game/script.rpy:1039
translate malay session_end_loop_91e0f0c9:

    # e "Select whether to proceed."
    e "Sila pilih sama ada untuk meneruskan."

# game/script.rpy:1070
translate malay session_end_loop_fb7dd6d2:

    # e "A short calming exercise is available before ending."
    e "Satu latihan menenangkan diri yang ringkas tersedia sebelum menamatkan sesi."

# game/script.rpy:1071
translate malay session_end_loop_91e0f0c9_1:

    # e "Select whether to proceed."
    e "Sila pilih sama ada untuk meneruskan."

# game/script.rpy:1107
translate malay affective_input_6e654e04:

    # e "[q!t]"
    e "[q!t]"

# game/script.rpy:1115
translate malay affective_input_b6bd024f:

    # e "For difficulty focusing, breaking tasks into smaller steps and completing one at a time is a practical way to stay on track."
    e "Bagi kesukaran menumpukan perhatian, memecahkan tugas kepada langkah yang lebih kecil dan menyelesaikannya satu demi satu ialah cara praktikal untuk kekal fokus."

# game/script.rpy:1122
translate malay affective_input_89917604:

    # e "A short breathing exercise is available before ending."
    e "Satu latihan pernafasan ringkas tersedia sebelum menamatkan sesi."

# game/script.rpy:1129
translate malay affective_input_5c68ff8f:

    # e "For persistent worry, setting aside a fixed time to address concerns keeps them from interrupting other activities."
    e "Bagi kebimbangan yang berterusan, menetapkan masa khusus untuk menangani kerisauan dapat mengelakkannya daripada mengganggu aktiviti lain."

# game/script.rpy:1136
translate malay affective_input_233f73a9:

    # e "For disrupted sleep, keeping a consistent sleep schedule and limiting screens before bed can improve rest."
    e "Bagi tidur yang terganggu, mengekalkan jadual tidur yang konsisten dan mengehadkan penggunaan skrin sebelum tidur dapat memperbaiki kualiti rehat."

# game/script.rpy:1145
translate malay affective_input_6e654e04_1:

    # e "[q!t]"
    e "[q!t]"

# game/script.rpy:1153
translate malay affective_input_201be3ea:

    # e "To balance caregiving with work or study, list your tasks and rank them by priority, then focus on the most urgent first."
    e "Untuk mengimbangi tugas penjagaan dengan kerja atau pengajian, senaraikan tugas anda dan susun mengikut keutamaan, kemudian fokus pada yang paling mendesak dahulu."

# game/script.rpy:1160
translate malay affective_input_afc1063e:

    # e "To manage household tasks alongside caregiving, group similar tasks together and delegate where possible to save time and energy."
    e "Untuk menguruskan kerja rumah seiring dengan tugas penjagaan, kumpulkan tugas yang serupa dan agihkan kepada orang lain jika boleh untuk menjimatkan masa dan tenaga."

# game/script.rpy:1167
translate malay affective_input_1b791ee0:

    # e "To protect time for yourself, schedule short fixed breaks into your day and treat them as fixed appointments."
    e "Untuk melindungi masa untuk diri sendiri, jadualkan waktu rehat pendek yang tetap dalam hari anda dan anggaplah ia sebagai janji temu yang tetap."

# game/script.rpy:1174
translate malay affective_input_e5d0cee2:

    # e "For unexpected caregiving needs, preparing a backup plan and a contact list in advance reduces last-minute pressure."
    e "Bagi keperluan penjagaan yang tidak dijangka, menyediakan pelan sokongan dan senarai hubungan lebih awal dapat mengurangkan tekanan saat akhir."

# game/script.rpy:1183
translate malay affective_input_6e654e04_2:

    # e "[q!t]"
    e "[q!t]"

# game/script.rpy:1191
translate malay affective_input_f7bec03a:

    # e "For worry about the person you care for, focus on what is within your control and note specific concerns to discuss with their healthcare provider."
    e "Bagi kebimbangan tentang orang yang anda jaga, fokus pada perkara yang berada dalam kawalan anda dan catatkan kerisauan tertentu untuk dibincangkan dengan penyedia penjagaan kesihatan mereka."

# game/script.rpy:1198
translate malay affective_input_2a711ca9:

    # e "With too many responsibilities, prioritise the essential tasks and postpone or delegate the non-urgent ones to free up capacity."
    e "Apabila terlalu banyak tanggungjawab, utamakan tugas yang penting dan tangguhkan atau agihkan tugas yang tidak mendesak untuk melapangkan kapasiti."

# game/script.rpy:1205
translate malay affective_input_4e86de43:

    # e "For limited rest or support, contacting community resources or respite-care services can provide additional help."
    e "Bagi rehat atau sokongan yang terhad, menghubungi sumber komuniti atau perkhidmatan penjagaan rehat boleh memberikan bantuan tambahan."

# game/script.rpy:1212
translate malay affective_input_78d5664f:

    # e "Identifying the specific source of the pressure is a useful first step toward addressing it."
    e "Mengenal pasti punca khusus tekanan itu merupakan langkah pertama yang berguna untuk menanganinya."

# game/script.rpy:1225
translate malay affective_input_511439e5:

    # e "When stress builds up like this, it helps to take one priority at a time rather than everything at once."
    e "Apabila tekanan terkumpul seperti ini, lebih baik menangani satu keutamaan pada satu masa berbanding semuanya serentak."

# game/script.rpy:1226
translate malay affective_input_7620f366:

    # e "Writing tasks down and ranking them by urgency can support workload organisation."
    e "Menulis tugas dan menyusunnya mengikut tahap kepentingan dapat membantu penyusunan beban kerja."

# game/script.rpy:1228
translate malay affective_input_2a6ea3a1:

    # e "A good starting point is to pick out your most urgent tasks and focus on those first."
    e "Permulaan yang baik adalah dengan memilih tugas yang paling mendesak dan memberi tumpuan kepadanya dahulu."

# game/script.rpy:1229
translate malay affective_input_a08331c7:

    # e "Non-essential tasks can be deferred to reduce immediate task load."
    e "Tugas yang tidak penting boleh ditangguhkan untuk mengurangkan beban tugas serta-merta."

# game/script.rpy:1240
translate malay post_response_fc04f621:

    # e "[feedback_prompt!t]"
    e "[feedback_prompt!t]"

# game/script.rpy:1264
translate malay post_response_b8706568:

    # e "Response recorded."
    e "Jawapan direkodkan."

# game/script.rpy:1305
translate malay calming_loop_02809623:

    # e "Another support options will use."
    e "Satu lagi pilihan sokongan akan digunakan."

# game/script.rpy:1312
translate malay calming_loop_ab4889ce:

    # e "Select your current stress state."
    e "Sila pilih tahap tekanan anda sekarang."

# game/script.rpy:1358
translate malay calming_loop_21057675:

    # e "Alright, we'll stop the exercise here."
    e "Baiklah, kita akan menghentikan latihan di sini."

# game/script.rpy:1363
translate malay calming_loop_4ea7ddf2:

    # e "That's the end of this exercise."
    e "Itulah penghujung latihan ini."

# game/script.rpy:1364
translate malay calming_loop_eb584e00:

    # e "These techniques can be repeated after the session ends."
    e "Teknik-teknik ini boleh diulang selepas sesi tamat."

# game/script.rpy:1370
translate malay calming_loop_5ff4067c:

    # e "Let's try a different exercise."
    e "Mari kita cuba latihan yang berbeza."

# game/script.rpy:1374
translate malay calming_loop_5d6cbe1c:

    # e "That's the last exercise."
    e "Itulah latihan yang terakhir."

# game/script.rpy:1375
translate malay calming_loop_56e19297:

    # e "If high stress persists, consider Befrienders or professional healthcare support."
    e "Jika tekanan yang tinggi berterusan, pertimbangkan untuk menghubungi Befrienders atau sokongan penjagaan kesihatan profesional."

# game/script.rpy:1396
translate malay deliver_technique_145f77cf:

    # e "This is a breathing exercise."
    e "Ini ialah latihan pernafasan."

# game/script.rpy:1397
translate malay deliver_technique_fe618d9c:

    # e "Under stress, breathing tends to become quicker and shallower."
    e "Ketika tertekan, pernafasan cenderung menjadi lebih cepat dan cetek."

# game/script.rpy:1398
translate malay deliver_technique_7e8b5154:

    # e "Slowing the breath can lower the physical signs of stress."
    e "Memperlahankan pernafasan dapat mengurangkan tanda-tanda fizikal tekanan."

# game/script.rpy:1400
translate malay deliver_technique_646f8169:

    # e "Follow this pattern."
    e "Ikut corak ini."

# game/script.rpy:1402
translate malay deliver_technique_7a353ce0:

    # e "Breathe in through your nose for four counts."
    e "Tarik nafas melalui hidung selama empat kiraan."

# game/script.rpy:1403
translate malay deliver_technique_d3655eb1:

    # e "In.. one, two, three, four."
    e "Tarik... satu, dua, tiga, empat."

# game/script.rpy:1404
translate malay deliver_technique_2d2ba602:

    # e "Hold."
    e "Tahan."

# game/script.rpy:1405
translate malay deliver_technique_89e41e7b:

    # e "Hold.. two, three,four, five, six, seven."
    e "Tahan... dua, tiga, empat, lima, enam, tujuh."

# game/script.rpy:1406
translate malay deliver_technique_823aac05:

    # e "Breathe out through your mouth for eight counts."
    e "Hembus nafas melalui mulut selama lapan kiraan."

# game/script.rpy:1407
translate malay deliver_technique_f3f5f042:

    # e "two, three, four, five, six, seven, eight."
    e "dua, tiga, empat, lima, enam, tujuh, lapan."

# game/script.rpy:1409
translate malay deliver_technique_f1f22ae2:

    # e "Repeat once more."
    e "Ulang sekali lagi."

# game/script.rpy:1410
translate malay deliver_technique_d3655eb1_1:

    # e "In.. one, two, three, four."
    e "Tarik... satu, dua, tiga, empat."

# game/script.rpy:1411
translate malay deliver_technique_9b6c8794:

    # e "Hold.. two, three, four, five, six, seven."
    e "Tahan... dua, tiga, empat, lima, enam, tujuh."

# game/script.rpy:1412
translate malay deliver_technique_966ef7e6:

    # e "And out.. two, three, four, five, six, seven, eight."
    e "Dan hembus... dua, tiga, empat, lima, enam, tujuh, lapan."

# game/script.rpy:1414
translate malay deliver_technique_b378916c:

    # e "A few slow breaths can reduce the body's stress response."
    e "Beberapa nafas yang perlahan dapat mengurangkan tindak balas tekanan badan."

# game/script.rpy:1418
translate malay deliver_technique_728d8ebb:

    # e "This is the 5-4-3-2-1 grounding technique."
    e "Ini ialah teknik grounding 5-4-3-2-1."

# game/script.rpy:1419
translate malay deliver_technique_1616a195:

    # e "It redirects attention to the present using the senses."
    e "Ia mengalihkan perhatian kepada masa kini menggunakan deria."

# game/script.rpy:1421
translate malay deliver_technique_4be2586f:

    # e "Identify 5 things you can see."
    e "Kenal pasti 5 perkara yang anda boleh lihat."

# game/script.rpy:1422
translate malay deliver_technique_e9dcd51c:

    # e "Identify 4 things you can physically touch."
    e "Kenal pasti 4 perkara yang anda boleh sentuh secara fizikal."

# game/script.rpy:1423
translate malay deliver_technique_7d8ba171:

    # e "Identify 3 sounds you can hear."
    e "Kenal pasti 3 bunyi yang anda boleh dengar."

# game/script.rpy:1424
translate malay deliver_technique_c77a6b39:

    # e "Identify 2 things you can smell, or recall smelling."
    e "Kenal pasti 2 perkara yang anda boleh hidu, atau yang anda ingat pernah dihidu."

# game/script.rpy:1425
translate malay deliver_technique_2f2dab18:

    # e "Identify 1 thing you can taste."
    e "Kenal pasti 1 perkara yang anda boleh rasa."

# game/script.rpy:1427
translate malay deliver_technique_fd336756:

    # e "Grounding can interrupt racing thoughts and bring focus back to the present."
    e "Teknik grounding dapat menghentikan fikiran yang berkecamuk dan mengembalikan tumpuan kepada masa kini."

# game/script.rpy:1431
translate malay deliver_technique_3d22079b:

    # e "This is a body scan exercise."
    e "Ini ialah latihan imbasan badan."

# game/script.rpy:1432
translate malay deliver_technique_4139485c:

    # e "Stress often produces physical tension without notice."
    e "Tekanan sering menghasilkan ketegangan fizikal tanpa disedari."

# game/script.rpy:1433
translate malay deliver_technique_dc83db8d:

    # e "Common areas are the shoulders, jaw, neck, and hands."
    e "Kawasan yang biasa terlibat ialah bahu, rahang, leher dan tangan."

# game/script.rpy:1435
translate malay deliver_technique_5455e64d:

    # e "Direct your attention to your body, one area at a time."
    e "Tumpukan perhatian anda kepada badan, satu kawasan pada satu masa."

# game/script.rpy:1437
translate malay deliver_technique_b6e6de91:

    # e "Shoulders: let them drop away from your ears."
    e "Bahu: biarkan ia turun menjauhi telinga anda."

# game/script.rpy:1438
translate malay deliver_technique_8b6e0d96:

    # e "Jaw: let it loosen."
    e "Rahang: biarkan ia mengendur."

# game/script.rpy:1439
translate malay deliver_technique_591fd175:

    # e "Hands: let them rest."
    e "Tangan: biarkan ia berehat."

# game/script.rpy:1440
translate malay deliver_technique_e15bdbc0:

    # e "Then scan the neck, chest, and stomach for tension."
    e "Kemudian imbas leher, dada dan perut untuk mengesan ketegangan."

# game/script.rpy:1442
translate malay deliver_technique_7e004706:

    # e "Where you find tension, note it without trying to change it."
    e "Di mana anda menemui ketegangan, perhatikannya tanpa cuba mengubahnya."

# game/script.rpy:1443
translate malay deliver_technique_b9094b5f:

    # e "Noticing where tension sits is the first step to releasing it."
    e "Menyedari di mana ketegangan berada ialah langkah pertama untuk melepaskannya."

# game/script.rpy:1447
translate malay deliver_technique_4732b74c:

    # e "This is a gratitude exercise."
    e "Ini ialah latihan kesyukuran."

# game/script.rpy:1449
translate malay deliver_technique_3864c6b7:

    # e "Under stress, attention narrows toward problems and unfinished tasks."
    e "Ketika tertekan, perhatian menyempit ke arah masalah dan tugas yang belum selesai."

# game/script.rpy:1450
translate malay deliver_technique_456dd2be:

    # e "Noting something positive can offset that bias."
    e "Memperhatikan sesuatu yang positif dapat mengimbangi kecenderungan itu."

# game/script.rpy:1452
translate malay deliver_technique_26cc645d:

    # e "Identify one thing that has been good or useful recently."
    e "Kenal pasti satu perkara yang baik atau berguna kebelakangan ini."

# game/script.rpy:1453
translate malay deliver_technique_1b3a10dc:

    # e "It does not need to be significant."
    e "Ia tidak semestinya sesuatu yang besar."

# game/script.rpy:1454
translate malay deliver_technique_d7c79250:

    # e "Examples: a conversation, a meal, or a quiet moment."
    e "Contohnya: satu perbualan, satu hidangan, atau satu saat yang tenang."

# game/script.rpy:1456
translate malay deliver_technique_62459bbb:

    # e "Hold that example in mind for a few seconds."
    e "Pegang contoh itu dalam fikiran selama beberapa saat."

# game/script.rpy:1457
translate malay deliver_technique_1f0348f0:

    # e "Brief positive recall can shift attention away from stressors."
    e "Mengingati perkara positif secara ringkas dapat mengalihkan perhatian daripada punca tekanan."

# game/script.rpy:1463
translate malay deliver_technique_ac19499b:

    # e "This is a guided imagery exercise."
    e "Ini ialah latihan imaginasi berpandu."

# game/script.rpy:1464
translate malay deliver_technique_01eb6f05:

    # e "It involves picturing a calm location in detail."
    e "Ia melibatkan membayangkan satu lokasi yang tenang secara terperinci."

# game/script.rpy:1465
translate malay deliver_technique_71dcc038:

    # e "It is commonly used to reduce stress in the moment."
    e "Ia lazim digunakan untuk mengurangkan tekanan pada ketika itu."

# game/script.rpy:1467
translate malay deliver_technique_87cfd9ce:

    # e "Choose a place you find calm, such as a beach, a lake, or a forest."
    e "Pilih satu tempat yang anda rasa tenang, seperti pantai, tasik, atau hutan."

# game/script.rpy:1469
translate malay deliver_technique_9765f73c:

    # e "Picture the scene."
    e "Bayangkan suasana itu."

# game/script.rpy:1470
translate malay deliver_technique_f00e8aa7:

    # e "Note what is visible: colours, light, and detail."
    e "Perhatikan apa yang kelihatan: warna, cahaya dan perincian."

# game/script.rpy:1471
translate malay deliver_technique_9192a07a:

    # e "Note the sounds, such as waves, birds, or wind."
    e "Perhatikan bunyi-bunyi, seperti ombak, burung, atau angin."

# game/script.rpy:1472
translate malay deliver_technique_71bec475:

    # e "Note physical sensations, such as warmth, cool air, or the ground underfoot."
    e "Perhatikan sensasi fizikal, seperti kehangatan, udara yang nyaman, atau permukaan tanah di bawah kaki."

# game/script.rpy:1474
translate malay deliver_technique_5fc73334:

    # e "Take one slow breath in."
    e "Tarik satu nafas yang perlahan."

# game/script.rpy:1475
translate malay deliver_technique_6a8e7eb0:

    # e "And out."
    e "Dan hembuskan."

